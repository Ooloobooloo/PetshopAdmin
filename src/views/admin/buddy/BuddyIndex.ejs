<%- include('../../partials/header') %>


<div class="container mt-4">
    <h1 class="mb-4">Danh sách thú cưng</h1>
    <a href="/admin/buddy/create" class="btn btn-primary mb-3">Thêm thú cưng mới</a>
    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Tên</th>
                    <th>Danh mục</th>
                    <th>Tuổi</th>
                    <th>Giới tính</th>
                    <th>Giống loài</th>
                    <th>Hình ảnh</th>
                    <th>Mô tả</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                <% if (buddies.length > 0) { %>
                    <% buddies.forEach(buddy => { %>
                        <tr>
                            <td><%= buddy.name %></td>
                            <td><%= buddy.category ? buddy.category.name : 'N/A' %></td>
                            <td><%= buddy.age %></td>
                            <td><%= buddy.gender %></td>
                            <td><%= buddy.breed %></td>
                            <td><img src="<%= buddy.image %>" alt="<%= buddy.name %>" class="img-thumbnail" style="width: 50px;"></td>
                            <td><%= buddy.description %></td>
                            <td>
                                <a href="/admin/buddy/edit/<%= buddy._id %>" class="btn btn-warning btn-sm">Sửa</a>
                                <form action="/admin/buddy/delete/<%= buddy._id %>" method="POST" class="d-inline">
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Bạn có chắc muốn xóa?')">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="8" class="text-center">Không có thú cưng nào.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../../partials/footer') %>