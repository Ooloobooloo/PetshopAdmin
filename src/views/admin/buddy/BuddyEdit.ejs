<%- include('../../partials/header') %>

<div class="container mt-4">
    <h1 class="mb-4">Sửa thú cưng</h1>
    <form action="/admin/buddy/update/<%= buddy._id %>" method="POST" class="row g-3">
        <div class="col-md-6">
            <label for="name" class="form-label">Tên:</label>
            <input type="text" id="name" name="name" class="form-control" value="<%= buddy.name %>" required>
        </div>

        <div class="col-md-6">
            <label for="category" class="form-label">Danh mục:</label>
            <select id="category" name="category" class="form-select" required>
                <% categories.forEach(category => { %>
                    <option value="<%= category._id %>" <%= buddy.category && buddy.category._id.equals(category._id) ? 'selected' : '' %>><%= category.name %></option>
                <% }) %>
            </select>
        </div>

        <div class="col-md-4">
            <label for="age" class="form-label">Tuổi:</label>
            <input type="number" id="age" name="age" class="form-control" value="<%= buddy.age %>" required>
        </div>

        <div class="col-md-4">
            <label for="gender" class="form-label">Giới tính:</label>
            <select id="gender" name="gender" class="form-select" required>
                <option value="Đực" <%= buddy.gender === 'Đực' ? 'selected' : '' %>>Đực</option>
                <option value="Cái" <%= buddy.gender === 'Cái' ? 'selected' : '' %>>Cái</option>
            </select>
        </div>

        <div class="col-md-4">
            <label for="breed" class="form-label">Giống loài:</label>
            <input type="text" id="breed" name="breed" class="form-control" value="<%= buddy.breed %>" required>
        </div>

        <div class="col-12">
            <label for="image" class="form-label">Hình ảnh (URL):</label>
            <input type="url" id="image" name="image" class="form-control" value="<%= buddy.image %>">
        </div>

        <div class="col-12">
            <label for="description" class="form-label">Mô tả:</label>
            <textarea id="description" name="description" class="form-control" rows="3"><%= buddy.description %></textarea>
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary">Cập nhật</button>
            <a href="/admin/buddy/list" class="btn btn-secondary">Hủy</a>
        </div>
    </form>
</div>

<%- include('../../partials/footer') %>