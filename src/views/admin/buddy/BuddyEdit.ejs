<%- include('../../partials/header') %>

<main>
    <h1>Sửa thú cưng</h1>
    <form action="/admin/buddy/update/<%= buddy._id %>" method="POST">
        <label for="name">Tên:</label>
        <input type="text" id="name" name="name" value="<%= buddy.name %>" required><br><br>

        <label for="category">Danh mục:</label>
        <select id="category" name="category" required>
            <% categories.forEach(category => { %>
                <option value="<%= category._id %>" <%= buddy.category && buddy.category._id.equals(category._id) ? 'selected' : '' %>><%= category.name %></option>
            <% }) %>
        </select><br><br>

        <label for="age">Tuổi:</label>
        <input type="number" id="age" name="age" value="<%= buddy.age %>" required><br><br>

        <label for="gender">Giới tính:</label>
        <select id="gender" name="gender" required>
            <option value="Đực" <%= buddy.gender === 'Đực' ? 'selected' : '' %>>Đực</option>
            <option value="Cái" <%= buddy.gender === 'Cái' ? 'selected' : '' %>>Cái</option>
        </select><br><br>

        <label for="breed">Giống loài:</label>
        <input type="text" id="breed" name="breed" value="<%= buddy.breed %>" required><br><br>

        <label for="image">Hình ảnh (URL):</label>
        <input type="url" id="image" name="image" value="<%= buddy.image %>"><br><br>

        <label for="description">Mô tả:</label>
        <textarea id="description" name="description"><%= buddy.description %></textarea><br><br>

        <button type="submit">Cập nhật</button>
    </form>
</main>

<%- include('../../partials/footer') %>