<%- include('../../partials/header') %>

<main>
    <h1>Thêm thú cưng mới</h1>
    <form action="/admin/buddy/store" method="POST">
        <label for="name">Tên:</label>
        <input type="text" id="name" name="name" required><br><br>

        <label for="category">Danh mục:</label>
        <select id="category" name="category" required>
            <% categories.forEach(category => { %>
                <option value="<%= category._id %>"><%= category.name %></option>
            <% }) %>
        </select><br><br>

        <label for="age">Tuổi:</label>
        <input type="number" id="age" name="age" required><br><br>

        <label for="gender">Giới tính:</label>
        <select id="gender" name="gender" required>
            <option value="Đực">Đực</option>
            <option value="Cái">Cái</option>
        </select><br><br>

        <label for="breed">Giống loài:</label>
        <input type="text" id="breed" name="breed" required><br><br>

        <label for="image">Hình ảnh (URL):</label>
        <input type="url" id="image" name="image"><br><br>

        <label for="description">Mô tả:</label>
        <textarea id="description" name="description"></textarea><br><br>

        <button type="submit">Thêm</button>
    </form>
</main>

<%- include('../../partials/footer') %>